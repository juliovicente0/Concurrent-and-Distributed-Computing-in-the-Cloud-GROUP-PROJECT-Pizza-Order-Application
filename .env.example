# =========================================================
# Pizza App - environment variables example
# Copy to .env and fill in real values. NEVER commit .env.
# =========================================================

# Node / app
NODE_ENV=production
PORT=8080

# JWT signing key — use a long random string in production
JWT_KEY=change-me-to-a-long-random-string

# Database (these names match what docker-compose uses)
DB_NAME=pizzeria
DB_USER=admin
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-too

# These two are FIXED inside docker-compose (the app talks to the "db" service
# over the internal network on port 3306). Listed here just for reference.
DB_HOST=db
DB_PORT=3306

# Image to pull in production (used by docker-compose on the VM).
# Override per environment, e.g. ghcr.io/<owner>/pizza-app:main
APP_IMAGE=ghcr.io/elmanin/pizza-app:latest
